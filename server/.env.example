# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# In development this defaults to http://localhost:8080 and http://127.0.0.1:8080
# so you only need this in production.
ALLOWED_ORIGINS=https://edura.example.com

# ── SMTP / Contact form email ─────────────────────────────────────────────────
# Leave SMTP_HOST empty to skip email sending (messages are still saved to disk).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
CONTACT_TO_EMAIL=team@example.com
CONTACT_FROM_EMAIL=noreply@example.com
